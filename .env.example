# Airtable Configuration
# Get these values from your Airtable account:
# 1. Go to airtable.com and sign up (free)
# 2. Create a new Base called "Judo Classes"
# 3. Create a table with these fields:
#    - day (Single line text)
#    - time (Single line text, e.g., "7:00 pm")
#    - endTime (Single line text, e.g., "8:30 pm")
#    - program (Single line text)
#    - category (Single select: "kids" or "adults")
#    - ageGroup (Single line text)
#    - level (Single line text)
#    - status (Single select: "available", "limited", "enrolling")
#    - duration (Single line text)
#
# 4. Get your Base ID from the URL: https://airtable.com/app/[BASE_ID]/...
# 5. Get your API key: Account settings → API → Personal access tokens

AIRTABLE_TOKEN=your_personal_access_token_here
AIRTABLE_BASE_ID=your_base_id_here

# Email Service (Optional - for booking confirmations)
# Choose one: Resend, SendGrid, Nodemailer, etc.
# RESEND_API_KEY=your_resend_api_key_here
